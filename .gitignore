## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

.vs/
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]uild/
[bB]in/
[Oo]bj/

# Visual Studio cache
.vscode/

# Rider
.idea/

# OS files
Thumbs.db
.DS_Store

# Logs
*.log

# App settings (secrets)
appsettings.json
appsettings.*.json
