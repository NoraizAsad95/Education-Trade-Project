@model EducationTrade.Presentation.ViewModel.TaskViewModel

@{
    ViewData["Title"] = "Browse Tasks";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
        border-radius: 14px;
        padding: 32px 36px;
        margin-bottom: 32px;
        color: white;
    }

    .coin-pill {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 10px;
        padding: 10px 16px;
    }

    .btn-new-task {
        background: white;
        color: #4f46e5;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        padding: 10px 22px;
        text-decoration: none;
        transition: background 0.2s, transform 0.1s;
        display: inline-block;
    }

    .btn-new-task:hover {
        background: #f0f0ff;
        color: #4338ca;
        transform: translateY(-1px);
    }

    .task-card {
        border: 2px solid #e0e7ff;
        border-radius: 12px;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
        background: white;
    }

    .task-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(79, 70, 229, 0.12);
        border-color: #818cf8;
    }

    .task-card.is-my-task {
        border-color: #e5e7eb;
        background: #f9fafb;
    }

    .task-card.is-my-task:hover {
        border-color: #d1d5db;
        box-shadow: 0 6px 16px rgba(0,0,0,0.06);
    }

    .reward-badge {
        background: #f0fdf4;
        border: 1.5px solid #6ee7b7;
        color: #065f46;
        border-radius: 8px;
        padding: 5px 12px;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .accept-btn {
        background: #4f46e5;
        color: white;
        border: none;
        border-radius: 7px;
        font-weight: 600;
        padding: 6px 16px;
        font-size: 0.85rem;
        transition: background 0.2s;
    }

    .accept-btn:hover {
        background: #4338ca;
        color: white;
    }

    .modal-header-colored {
        background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
        color: white;
        padding: 20px 24px;
    }

    .modal-reward-block {
        background: linear-gradient(135deg, #ecfdf5, #d1fae5);
        border: 1.5px solid #6ee7b7;
        border-radius: 10px;
        padding: 16px 20px;
    }

    .modal-section-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        margin-bottom: 6px;
    }
</style>

<!-- Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="font-size: 1.8rem;">🎯 Browse Tasks</h2>
            <p class="mb-0 opacity-75 small">Find tasks, earn coins, and help fellow students.</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="coin-pill d-flex align-items-center gap-2">
                <i class="bi bi-coin fs-5" style="color: #34d399;"></i>
                <div>
                    <div style="font-size: 0.7rem; opacity: 0.8; line-height: 1;">@Model.UserName</div>
                    <div class="fw-bold" style="font-size: 0.95rem;">@Model.UserCoinBalance coins</div>
                </div>
            </div>
            <a asp-controller="Task" asp-action="CreateTask" class="btn-new-task">
                <i class="bi bi-plus-lg me-1"></i> New Task
            </a>
        </div>
    </div>
</div>

<div class="d-flex align-items-center mb-3">
    <span class="badge rounded-pill px-3 py-2" style="background:#ede9fe; color:#4f46e5; font-size:0.8rem;">
        <i class="bi bi-list-task me-1"></i> @Model.AvailableTasks.Count task@(Model.AvailableTasks.Count == 1 ? "" : "s") available
    </span>
</div>

<!-- Tasks Grid -->
@if (!Model.AvailableTasks.Any())
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-inbox" style="font-size: 64px; color:#c7d2fe;"></i>
        <h5 class="mt-3 fw-semibold text-muted">No tasks available right now</h5>
        <p class="text-muted small mb-4">Be the first to post a task and get help from the community.</p>
        <a asp-controller="Task" asp-action="CreateTask" class="btn px-4 py-2 text-white fw-semibold" style="background:#4f46e5; border-radius:8px;">Create a Task</a>
    </div>
}
else
{
    <div class="row g-4 px-1">
        @foreach (var task in Model.AvailableTasks)
        {
            bool isMyTask = task.CreatedById == Model.currentUserId;

            <div class="col-md-6 col-lg-4">
                <div class="card task-card h-100 @(isMyTask ? "is-my-task" : "")">
                    <div class="card-body p-4 d-flex flex-column">

                        <!-- Title & Status -->
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-semibold mb-0 me-2" style="line-height: 1.4; color: #1e1b4b;">@task.Title</h6>
                            <span class="badge text-dark flex-shrink-0" style="background:#d1fae5; border:1px solid #6ee7b7; color:#065f46 !important; font-size:0.7rem;">@task.Status</span>
                        </div>

                        <!-- Description -->
                        <p class="text-muted small mb-3" style="flex-grow: 1; min-height: 48px;">
                            @(task.Description.Length > 100 ? task.Description.Substring(0, 100) + "…" : task.Description)
                        </p>

                        <!-- Meta -->
                        <div class="d-flex justify-content-between align-items-center mb-3 pt-2 border-top">
                            <div class="small text-muted">
                                <i class="bi bi-person-circle me-1" style="color:#818cf8;"></i>
                                @task.CreatorName
                                @if (isMyTask)
                                {
                                    <span class="badge bg-secondary ms-1" style="font-size:0.62rem;">You</span>
                                }
                            </div>
                            <div class="small text-muted">
                                <i class="bi bi-clock me-1"></i>@task.TimeAgo
                            </div>
                        </div>

                        <!-- Reward & Actions -->
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="reward-badge">
                                <i class="bi bi-coin me-1"></i>@task.CoinReward coins
                            </span>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary"
                                        data-bs-toggle="modal" data-bs-target="#taskModal_@task.TaskId"
                                        style="border-radius:7px; font-size:0.82rem;">
                                    Details
                                </button>
                                @if (!isMyTask)
                                {
                                    <form asp-controller="Task" asp-action="Accept" asp-route-id="@task.TaskId" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="accept-btn"
                                                onclick="return confirm('Accept this task for @task.CoinReward coins?')">
                                            Accept
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" style="border-radius:7px; font-size:0.82rem;" disabled>Your Task</button>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    <p class="text-muted small text-center mt-4">Showing all @Model.AvailableTasks.Count tasks</p>
}

<!-- Task Detail Modals -->
@foreach (var task in Model.AvailableTasks)
{
    bool isMyTask = task.CreatedById == Model.currentUserId;

    <div class="modal fade" id="taskModal_@task.TaskId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:12px; overflow:hidden;">

                <!-- Colored Modal Header -->
                <div class="modal-header-colored d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="fw-bold mb-1">@task.Title</h5>
                        <span class="badge" style="background:#d1fae5; color:#065f46;">@task.Status</span>
                        <span class="ms-2 opacity-75 small"><i class="bi bi-clock me-1"></i>@task.TimeAgo</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white mt-1" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">

                    <!-- Description -->
                    <div class="mb-4">
                        <div class="modal-section-label">Description</div>
                        <div class="p-3 rounded-3" style="background:#f5f3ff; border:1px solid #e0e7ff;">
                            <p class="mb-0" style="white-space: pre-line; color:#3730a3;">@task.Description</p>
                        </div>
                    </div>

                    <!-- Posted By -->
                    <div class="mb-4">
                        <div class="modal-section-label">Posted By</div>
                        <div class="d-flex align-items-center gap-2 p-3 rounded-3" style="background:#f0fdf4; border:1px solid #bbf7d0;">
                            <i class="bi bi-person-circle fs-4" style="color:#16a34a;"></i>
                            <span class="fw-semibold text-dark">@task.CreatorName</span>
                            @if (isMyTask)
                            {
                                <span class="badge bg-secondary">You</span>
                            }
                        </div>
                    </div>

                    <!-- Reward -->
                    <div class="mb-4">
                        <div class="modal-section-label">Reward</div>
                        <div class="modal-reward-block d-flex align-items-center gap-3">
                            <i class="bi bi-coin fs-2" style="color:#059669;"></i>
                            <div>
                                <div class="fw-bold fs-4" style="color:#065f46;">@task.CoinReward Coins</div>
                                <div class="small" style="color:#047857;">Earned upon task completion</div>
                            </div>
                        </div>
                    </div>

                    <!-- Created -->
                    <div>
                        <div class="modal-section-label">Created</div>
                        <p class="mb-0 small text-muted">@task.CreatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
                    </div>
                </div>

                <div class="modal-footer border-top px-4 py-3">
                    @if (isMyTask)
                    {
                        <div class="w-100 text-center">
                            <p class="text-muted small mb-2">You cannot accept your own task.</p>
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    }
                    else
                    {
                        <div class="w-100 d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Balance: <strong>@Model.UserCoinBalance coins</strong></span>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                                <form asp-controller="Task" asp-action="AcceptTask" asp-route-id="@task.TaskId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn px-4 fw-semibold text-white" style="background:#4f46e5; border-radius:8px;"
                                            onclick="return confirm('Accept this task for @task.CoinReward coins?')">
                                        <i class="bi bi-check-circle me-1"></i> Accept Task
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
