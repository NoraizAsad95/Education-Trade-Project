@model EducationTrade.Presentation.ViewModel.TaskViewModel

@{
    ViewData["Title"] = "Browse Tasks";
}

<style>
    
    .page-header {
        background: linear-gradient(135deg, #0D9BD4 0%, #118abf 100%);
        border-radius: 14px;
        padding: 32px 36px;
        margin-bottom: 32px;
        color: white;
        box-shadow: 0 10px 25px rgba(13, 155, 212, 0.3); 
    }

   
    .coin-pill {
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        padding: 12px 20px;
        backdrop-filter: blur(5px);
    }

    
    .btn-new-task {
        background: white;
        color: #0D9BD4 !important; 
        font-weight: 600;
        border: none;
        border-radius: 8px;
        padding: 10px 22px;
        text-decoration: none;
        transition: background 0.2s, transform 0.1s;
        display: flex;
        align-items: center;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }

        .btn-new-task:hover {
            background: #f8f9fa;
            color: #118abf !important;
            transform: translateY(-2px);
        }

    /* The ultra-simple, horizontal list box */
    .task-list-row {
        background: #ffffff;
        border: 1px solid #e2e8f0; /* Soft grey default */
        border-radius: 8px; /* Slightly sharper corners for a professional software look */
        transition: border-color 0.2s ease;
    }
        /* Only change the border color to your sleek Charcoal Grey, absolutely no movement */
        .task-list-row:hover {
            border-color: #3D3F44;
        }

    .task-card {
        border: 2px solid #e0e7ff;
        border-radius: 12px;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
        background: white;
    }

    .task-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(79, 70, 229, 0.12);
        border-color: #818cf8;
    }

    .task-card.is-my-task {
        border-color: #e5e7eb;
        background: #f9fafb;
    }

    .task-card.is-my-task:hover {
        border-color: #d1d5db;
        box-shadow: 0 6px 16px rgba(0,0,0,0.06);
    }

    .reward-badge {
        background: #f0fdf4;
        border: 1.5px solid #6ee7b7;
        color: #065f46;
        border-radius: 8px;
        padding: 5px 12px;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .accept-btn {
        background: #4f46e5;
        color: white;
        border: none;
        border-radius: 7px;
        font-weight: 600;
        padding: 6px 16px;
        font-size: 0.85rem;
        transition: background 0.2s;
    }

    .accept-btn:hover {
        background: #4338ca;
        color: white;
    }

    .modal-header-colored {
        background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
        color: white;
        padding: 20px 24px;
    }

    .modal-reward-block {
        background: linear-gradient(135deg, #ecfdf5, #d1fae5);
        border: 1.5px solid #6ee7b7;
        border-radius: 10px;
        padding: 16px 20px;
    }

    .modal-section-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        margin-bottom: 6px;
    }
</style>

<!-- Header -->

<div class="container py-4">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
               
                <h2 class="fw-bold mb-1" style="font-size: 2rem; letter-spacing: -0.5px;">🎯 Browse Tasks</h2>
                
                <p class="mb-0 opacity-75" style="font-size: 1.05rem;">Find tasks, earn coins, and help fellow students.</p>
            </div>

            <div class="d-flex align-items-center gap-3">
                
                <div class="coin-pill d-flex align-items-center gap-2">
                   
                    <div class="bg-white rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                        <i class="bi bi-coin fs-5" style="color: #34d399;"></i>
                    </div>
                    <div>
                        <div style="font-size: 0.75rem; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">@Model.UserName</div>
                        <div class="fw-bold" style="font-size: 1.1rem;">@Model.UserCoinBalance Coins</div>
                    </div>
                </div>

                <a asp-controller="Task" asp-action="CreateTask" hx-boost="true"  class="btn-new-task">
                    <i class="bi bi-plus-circle-fill me-2 fs-5"></i> New Task
                </a>
            </div>
        </div>
    </div>



<div class="d-flex align-items-center mb-3">
    <span class="badge rounded-pill px-3 py-2 fw-semibold" style="background-color: rgba(13, 155, 212, 0.1); color: #0D9BD4; font-size: 0.85rem;">
        <i class="bi bi-list-task me-1"></i> @Model.AvailableTasks.Count task@(Model.AvailableTasks.Count == 1 ? "" : "s") available
    </span>
</div>
<!-- Tasks Grid -->
@if (!Model.AvailableTasks.Any())
{
    <!-- Updated Empty State matching your custom blue and grey -->
    <div class="text-start py-5 my-4 border rounded p-5 bg-white" style="border-color: #e2e8f0 !important;">
        <i class="bi bi-inbox text-brand-grey" style="font-size: 48px; opacity: 0.6;"></i>
        <h5 class="mt-3 fw-bold text-brand-grey">No tasks available right now</h5>
        <p class="text-muted small mb-4" style="max-width: 400px;">There are no active tasks waiting to be completely. Be the first to post a task and get help from the community!</p>
        <a asp-controller="Task" asp-action="CreateTask" class="btn px-4 py-2 text-white fw-semibold" style="background-color: #0D9BD4; border-radius: 6px;">
            <i class="bi bi-plus-lg me-1"></i> Create a Task
        </a>
    </div>
}
else
{
    <!-- Notice we removed 'mx-auto' and max-width. It now flows naturally from the left. -->
    <div class="d-flex flex-column gap-3 w-100">
        @foreach (var task in Model.AvailableTasks)
        {
            bool isMyTask = task.CreatedById == Model.currentUserId;

            <div class="task-list-row p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">

                <!-- LEFT SIDE: Info -->
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <h5 class="fw-bold mb-0 text-brand-grey" style="font-size: 1.15rem;">@task.Title</h5>

                        @if (isMyTask)
                        {
                            <span class="badge bg-light text-muted border border-secondary">Your Task</span>
                        }
                    </div>

                    <p class="text-muted mb-2" style="font-size: 0.95rem;">
                        @(task.Description.Length > 150 ? task.Description.Substring(0, 150) + "..." : task.Description)
                    </p>

                    <div class="d-flex gap-4 small text-muted">
                        <span><i class="bi bi-person me-1" style="color: #0D9BD4;"></i> @task.CreatorName</span>
                        <span><i class="bi bi-clock me-1"></i> @task.TimeAgo</span>
                    </div>
                </div>

                <!-- RIGHT SIDE: Rewards & Actions -->
                <div class="d-flex flex-md-column align-items-md-end align-items-center justify-content-between gap-2 mt-3 mt-md-0" style="min-width: 150px;">

                    <div class="fw-bold fs-5 text-success">
                        <i class="bi bi-coin"></i> @task.CoinReward <span class="fs-6 fw-normal text-muted">Coins</span>
                    </div>

                    <div class="d-flex gap-2 w-100 justify-content-end mt-1">
                        <button type="button" class="btn btn-sm btn-light border fw-bold text-brand-grey"
                                data-bs-toggle="modal" data-bs-target="#taskModal_@task.TaskId">
                            Details
                        </button>

                        @if (!isMyTask)
                        {
                            <form asp-controller="Task" asp-action="AcceptTask" asp-route-id="@task.TaskId" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm fw-bold text-white px-3"
                                        style="background-color: #0D9BD4;"
                                        onclick="return confirm('Accept this task for @task.CoinReward coins?')">
                                    Accept
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}


    <!-- Task Detail Modals -->
    @foreach (var task in Model.AvailableTasks)
    {
        bool isMyTask = task.CreatedById == Model.currentUserId;

        <div class="modal fade" id="taskModal_@task.TaskId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius:12px; overflow:hidden;">

                    <!-- Header -->
                    <div class="modal-header bg-light border-bottom px-4 py-3">
                        <div class="d-flex flex-column">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <h5 class="fw-bold mb-0 text-dark">@task.Title</h5>
                                <span class="badge border border-secondary text-secondary bg-white">@task.Status</span>
                            </div>
                            <span class="text-muted small"><i class="bi bi-clock me-1"></i>Posted @task.TimeAgo</span>
                        </div>
                        <button type="button" class="btn-close mb-auto mt-1" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body p-4">
                        <div class="row g-4">

                            <!-- Left Column: Description -->
                            <div class="col-md-8 border-end pe-md-4">
                                <h6 class="fw-bold text-uppercase text-muted mb-2" style="font-size: 0.8rem; letter-spacing: 0.5px;">Task Description</h6>
                                <div class="p-3 bg-light rounded" style="border: 1px solid #e9ecef;">
                                    <p class="mb-0 text-dark" style="white-space: pre-line; line-height: 1.6;">@task.Description</p>
                                </div>
                            </div>

                            <!-- Right Column: Meta Info -->
                            <div class="col-md-4">
                                <!-- Reward Content -->
                                <div class="mb-4">
                                    <h6 class="fw-bold text-uppercase text-muted mb-2" style="font-size: 0.8rem; letter-spacing: 0.5px;">Reward</h6>
                                    <div class="d-flex align-items-center gap-2 p-2 rounded" style="background-color: rgba(13, 155, 212, 0.05); border: 1px solid rgba(13, 155, 212, 0.2);">
                                        <i class="bi bi-coin fs-4" style="color: #0D9BD4;"></i>
                                        <div>
                                            <div class="fw-bold text-dark fs-5 mb-0">@task.CoinReward <span class="fs-6 fw-normal text-muted">Coins</span></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Posted By -->
                                <div>
                                    <h6 class="fw-bold text-uppercase text-muted mb-2" style="font-size: 0.8rem; letter-spacing: 0.5px;">Posted By</h6>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-person-circle fs-3 text-secondary"></i>
                                        <div>
                                            <div class="fw-semibold text-dark">@task.CreatorName</div>
                                            @if (isMyTask)
                                            {
                                                <span class="badge bg-secondary" style="font-size: 0.65rem;">You</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer bg-light border-top px-4 py-3">
                        @if (isMyTask)
                        {
                            <div class="w-100 text-center">
                                <p class="text-muted small mb-0">You cannot accept your own task.</p>
                            </div>
                        }
                        else
                        {
                            <div class="w-100 d-flex justify-content-between align-items-center">
                                <span class="text-muted small">Your Balance: <strong>@Model.UserCoinBalance coins</strong></span>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-outline-secondary fw-semibold" data-bs-dismiss="modal">Close</button>
                                    <form asp-controller="Task" asp-action="AcceptTask" asp-route-id="@task.TaskId" method="post" class="d-inline m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn text-white fw-bold px-4 shadow-sm" style="background-color: #0D9BD4;"
                                                onclick="return confirm('Do you want to accept this task and work for @task.CoinReward coins?')">
                                            <i class="bi bi-briefcase-fill me-1"></i> Accept Task
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    }

</div>
@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
