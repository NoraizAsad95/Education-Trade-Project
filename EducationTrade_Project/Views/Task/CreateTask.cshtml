@model EducationTrade.Web.ViewModels.CreateTaskViewModel

@{
    ViewData["Title"] = "Create Task";
}
<style>
    .textColor
    {
        color: #0D9BD4;
    }
</style>
<!-- Added 'container-md' and 'px' padding to create nice whitespace on the left and right -->
<div class="container-md px-4 px-lg-5 mt-4">

    <!-- 'gx-lg-5' creates a wider gap between the left and right columns -->
    <div class="row gx-lg-5">

        <!-- Left Column: The Main Form -->
        <div class="col-lg-8 col-md-12 mb-4">
            <div class="card shadow-sm border rounded-3">

                <!-- Explicit Card Header gives it a classic "Form" panel structure -->
                <div class="card-header bg-light border-bottom py-3 px-4 px-md-5">
                    <h4 class="mb-0 fw-bold textColor">Create a New Task</h4>
                    <p class="text-muted mb-0 small">Fill out the details below to request a service.</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-controller="Task" asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                        <!-- Task Title Input -->
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-semibold text-dark">
                                Task Title <span class="text-danger">*</span>
                            </label>
                            <!-- Classic white background and standard border makes it explicitly a form input -->
                            <input asp-for="Title" class="form-control form-control-lg border border-1" placeholder="e.g., Need help with Calculus assignment" />
                            <span asp-validation-for="Title" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                        <!-- Task Description TextArea -->
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold text-dark">
                                Detailed Description <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Description" class="form-control border border-1" placeholder="Explain what you need done..." style="height: 150px"></textarea>
                            <span asp-validation-for="Description" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                        <!-- Reward Number Input -->
                        <div class="mb-4">
                            <label asp-for="CoinReward" class="form-label fw-semibold text-dark">
                                Coin Reward Amount <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border border-1 border-end-0">🪙</span>
                                <input asp-for="CoinReward" type="number" class="form-control border border-1 border-start-0 ps-0" placeholder="0" min="1" max="1000" />
                            </div>
                            <div class="form-text mt-2 text-muted">
                                Your Available Balance: <strong class="text-success">@Model.UserCoinBalance Coins</strong>
                            </div>
                            <span asp-validation-for="CoinReward" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                        <hr class="my-4 opacity-25">

                        <!-- Submit Button matching the Application's deep blue (#0a58ca) -->
                        <div class="mt-4">
                            <button type="submit" class="btn btn-lg w-100 fw-bold rounded-2 text-white shadow-sm" style="background-color: #0a58ca; border-color: #0a58ca;">
                                Publish Task
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: User Info & Guidelines Panel -->
        <div class="col-lg-4 col-md-12">
            <div class="card shadow-sm border rounded-3 mb-4 bg-light">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-4">
                        <!-- Profile Avatar placeholder -->
                        <div class="d-inline-flex align-items-center justify-content-center bg-white border border-2 shadow-sm text-dark rounded-circle mb-3 fw-bold" style="width: 65px; height: 65px; font-size: 1.6rem; border-color: #0D9BD4  !important;">
                            @(Model.UserName?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                        <h5 class="fw-bold mb-1 text-dark">Hi, @Model.UserName! 👋</h5>
                        <p class="text-muted small">Let's get your task listed.</p>
                    </div>

                    <div class="bg-white p-4 rounded-3 border">
                        <h6 class="fw-bold mb-3 text-dark border-bottom pb-2">Guidelines for Success</h6>

                        <ul class="list-unstyled text-secondary mb-0">
                            <li class="mb-3 d-flex align-items-start">
                                <span class="me-2 fw-bold fs-5 lh-1 mt-1" style="color: #0D9BD4 ;">•</span>
                                <div class="small"><strong class="text-dark">Be specific:</strong> A clear description helps you get responses faster.</div>
                            </li>
                            <li class="mb-3 d-flex align-items-start">
                                <span class="me-2 fw-bold fs-5 lh-1 mt-1" style="color: #0D9BD4 ;">•</span>
                                <div class="small"><strong class="text-dark">Fair pricing:</strong> Offer a coin reward that matches the effort required.</div>
                            </li>
                            <li class="d-flex align-items-start">
                                <span class="me-2 fw-bold fs-5 lh-1 mt-1" style="color: #0D9BD4 ;">•</span>
                                <div class="small"><strong class="text-dark">Stay active:</strong> Don't forget to check back and accept students when they apply!</div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
