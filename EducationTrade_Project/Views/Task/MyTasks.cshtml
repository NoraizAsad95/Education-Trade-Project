@model EducationTrade.Web.ViewModels.MyTasksViewModel

@{
    ViewData["Title"] = "My Tasks";
}
<style>
    
    .my-tasks-header {
        background: linear-gradient(135deg, #0D9BD4 0%, #118abf 100%);
        border-radius: 14px;
        padding: 32px 36px;
        margin-bottom: 32px;
        color: white;
        box-shadow: 0 10px 25px rgba(13, 155, 212, 0.3);
    }

    
    .text-brand-grey {
        color: #545b62 !important;
    }
    .total{
        background-color: #0D9BD4
    }
   
    .header-coin-pill {
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        padding: 12px 20px;
        backdrop-filter: blur(5px);
    }

    .btn-custom-workspace {
        color: #0D9BD4;
        border: 2px solid #0D9BD4;
        background-color: transparent;
        transition: all 0.2s ease-in-out;
    }

        .btn-custom-workspace:hover,
        .btn-custom-workspace:active {
            background-color: #0D9BD4 !important;
            color: white !important;
            border-color: #0D9BD4 !important;
        }

    .btn:focus, .btn:active:focus, .nav-link:focus, .form-control:focus, button:focus {
        outline: none !important;
        box-shadow: none !important;
    }

    .nav-tabs .nav-link.active {
        color: #0D9BD4 !important;
        border-bottom: 3px solid #0D9BD4 !important;
    }

    .nav-tabs .nav-link {
        color: #6c757d;
        border: none;
        border-bottom: 3px solid transparent;
    }

        .nav-tabs .nav-link:hover {
            color: #0D9BD4;
            border-color: transparent;
        }
</style>



<div class="container py-4">
   
    <div class="my-tasks-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            
            <h2 class="fw-bold mb-1" style="font-size: 2rem; letter-spacing: -0.5px;">📋 Manage My Tasks</h2>
            <p class="mb-0 opacity-75" style="font-size: 1.05rem;">Track the tasks you've created and the work you've accepted.</p>
        </div>

        
        <div class="d-flex gap-3">
            <div class="header-coin-pill d-flex align-items-center gap-2">
                <div class="bg-white rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                    <i class="bi bi-arrow-down-left-circle-fill fs-5 text-success"></i>
                </div>
                <div>
                    <div style="font-size: 0.75rem; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Earned</div>
                    <div class="fw-bold" style="font-size: 1.1rem;">@Model.CoinsEarned <i class="bi bi-coin" style="color: #34d399;"></i></div>
                </div>
            </div>

            <div class="header-coin-pill d-flex align-items-center gap-2">
                <div class="bg-white rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                    <i class="bi bi-arrow-up-right-circle-fill fs-5 text-danger"></i>
                </div>
                <div>
                    <div style="font-size: 0.75rem; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Spent</div>
                    <div class="fw-bold" style="font-size: 1.1rem;">@Model.CoinsSpent <i class="bi bi-coin" style="color: #fca5a5;"></i></div>
                </div>
            </div>
        </div>
    </div>


    
    <ul class="nav nav-tabs shadow-sm" id="myTaskTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold" id="created-tab" data-bs-toggle="tab" data-bs-target="#created" type="button" role="tab" aria-controls="created" aria-selected="true">
                Tasks I Created <span class="badge total rounded-pill">@Model.TotalCreated</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold" id="accepted-tab" data-bs-toggle="tab" data-bs-target="#accepted" type="button" role="tab" aria-controls="accepted" aria-selected="false">
                Tasks I Accepted <span class="badge total rounded-pill">@Model.TotalAccepted</span>
            </button>
        </li>
    </ul>

    
    <div class="tab-content border border-top-0 bg-white p-4 shadow-sm rounded-bottom" id="myTaskTabsContent">

        
        <div class="tab-pane fade show active" id="created" role="tabpanel" aria-labelledby="created-tab">
            @if (!Model.CreatedTasks.Any())
            {
                <div class="alert alert-info border-0 shadow-sm"><i class="bi bi-info-circle"></i> You have not created any tasks yet.</div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var task in Model.CreatedTasks)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 shadow-sm border-0 bg-light">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title fw-bold text-brand-grey mb-0">@task.Title</h5>
                                        <span class="badge bg-warning text-dark"><i class="bi bi-coin"></i> @task.CoinReward</span>
                                    </div>
                                    <p class="card-text text-muted small mb-3 flex-grow-1">@(task.Description.Length > 100 ? task.Description.Substring(0, 100) + "..." : task.Description)</p>

                                    <div class="mb-3 small">
                                        <strong>Status:</strong>
                                        @if (task.Status == "Completed")
                                        {
                                            <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> @task.Status</span>
                                        }
                                        else if (task.Status == "PendingReview")
                                        {
                                            <span class="text-warning fw-bold"><i class="bi bi-exclamation-circle-fill"></i> Ready for Review</span>
                                        }
                                        else if (task.Status == "Accepted")
                                        {
                                            <span class="text-primary fw-bold"><i class="bi bi-clock-history"></i> @task.Status</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary fw-bold">@task.Status</span>
                                        }
                                    </div>

                                    <!-- BUTTON TO OPEN THE MODAL -->
                                    <!-- Change this on both the Created and Accepted cards -->
                                    <button type="button" class="btn btn-custom-workspace btn-sm w-100 mt-auto fw-bold" data-bs-toggle="modal" data-bs-target="#taskModal_@task.TaskId">
                                        <i class="bi bi-chat-left-text"></i> View Workspace
                                    </button>

                                </div>
                                <div class="card-footer bg-transparent border-0 text-muted small pb-3">
                                    Created: @task.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ACCEPTED TASKS TAB -->
        <div class="tab-pane fade" id="accepted" role="tabpanel" aria-labelledby="accepted-tab">
            @if (!Model.AcceptedTasks.Any())
            {
                <div class="alert alert-info border-0 shadow-sm"><i class="bi bi-info-circle"></i> You have not accepted any tasks to work on yet.</div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var task in Model.AcceptedTasks)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 shadow-sm border-0 bg-light">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title fw-bold text-brand-grey mb-0">@task.Title</h5>
                                        <span class="badge bg-success"><i class="bi bi-coin"></i> @task.CoinReward</span>
                                    </div>
                                    <p class="card-text text-muted small mb-3 flex-grow-1">@(task.Description.Length > 100 ? task.Description.Substring(0, 100) + "..." : task.Description)</p>

                                    <div class="mb-3 small">
                                        <strong>Status:</strong>
                                        @if (task.Status == "Completed")
                                        {
                                            <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> @task.Status</span>
                                        }
                                        else if (task.Status == "PendingReview")
                                        {
                                            <span class="text-warning fw-bold"><i class="bi bi-hourglass-split"></i> Under Review</span>
                                        }
                                        else
                                        {
                                            <span class="text-primary fw-bold"><i class="bi bi-tools"></i> In Progress</span>
                                        }
                                    </div>

                                    <!-- BUTTON TO OPEN THE MODAL -->
                                    <!-- Change this on both the Created and Accepted cards -->
                                    <button type="button" class="btn btn-custom-workspace btn-sm w-100 mt-auto fw-bold" data-bs-toggle="modal" data-bs-target="#taskModal_@task.TaskId">
                                        <i class="bi bi-chat-left-text"></i> View Workspace
                                    </button>

                                </div>
                                <div class="card-footer bg-transparent border-0 text-muted small pb-3">
                                    Accepted on: @task.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>



<!--  Modals -->
@foreach (var task in Model.CreatedTasks)
{
    <div class="modal fade" id="taskModal_@task.TaskId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:12px; overflow:hidden;">

                <!-- Header -->
                <div class="modal-header bg-light d-flex justify-content-between align-items-start border-0">
                    <div>
                        <h5 class="fw-bold text-brand-grey mb-1">@task.Title</h5>
                        <span class="badge bg-primary text-white">Reward: @task.CoinReward <i class="bi bi-coin"></i></span>
                        <span class="badge border border-secondary text-dark ms-1">Status: @task.Status</span>
                    </div>
                    <button type="button" class="btn-close mt-1" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-0">
                    <div class="row g-0">
                        <!-- LEFT COLUMN: Task Details -->
                        <div class="col-md-7 p-4 border-end">
                            <h6 class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Description</h6>
                            <div class="p-3 rounded bg-light mb-4">
                                <p class="mb-0 text-dark" style="white-space: pre-line;">@task.Description</p>
                            </div>

                            @if (!string.IsNullOrEmpty(task.OtherUserName))
                            {
                                <div class="mb-4">
                                    <h6 class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Worker Info</h6>
                                    <div class="d-flex align-items-center gap-2 p-3 rounded" style="background:#f8f9fa; border:1px solid #dee2e6;">
                                        <i class="bi bi-person-fill fs-4 text-primary"></i>
                                        <span class="fw-semibold text-dark">@task.OtherUserName <span class="text-muted small">(@task.OtherUserRating <i class="bi bi-star-fill text-warning"></i>)</span></span>
                                    </div>
                                </div>
                            }
                            
                            @if (task.Status == "Pending")
                            {
                                <div class="alert alert-secondary border-0 text-center mb-0 mt-3">
                                    <i class="bi bi-hourglass-split fs-4 d-block mb-1"></i>
                                    Waiting for a student to accept this task.
                                    <form asp-controller="Task" asp-action="CancelTask" method="post">
                                        <input type="hidden" name="id" value="@task.TaskId" />
                                        <button type="submit" class="btn btn-outline-danger w-100 fw-bold mt-3" onclick="return confirm('Cancel this task and refund coins?');">
                                            <i class="bi bi-x-circle"></i> Cancel Task
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>

                        <!-- RIGHT COLUMN: Chat & Actions -->
                        <div class="col-md-5 d-flex flex-column" style="background: #f9fafb;">

                            <!-- Chat Feed -->
                            <div class="p-3 flex-grow-1" style="min-height: 250px; max-height: 400px; overflow-y: auto;">
                                <h6 class="fw-bold text-muted mb-3"><i class="bi bi-chat-dots"></i> Task Handover Activity</h6>
                                @if (task.Messages == null || !task.Messages.Any())
                                {
                                    <p class="text-muted small text-center mt-4">No activity yet.</p>
                                }
                                else
                                {
                                    @foreach (var msg in task.Messages)
                                    {
                                        @if (msg.MessageText.StartsWith("SYSTEM:"))
                                        {
                                            <!-- Display as a neutral System Event in the center -->
                                            <div class="text-center my-3">
                                                <span class="badge bg-secondary rounded-pill py-2 px-3 shadow-sm text-wrap" style="max-width: 90%; font-weight: normal;">
                                                    <i class="bi bi-info-circle me-1"></i> @msg.MessageText.Replace("SYSTEM:", "")
                                                </span>
                                                <div class="small text-muted mt-1" style="font-size: 0.65rem;">@msg.TimeAgo</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Display as a normal chat bubble -->
                                            <div class="mb-3 @(msg.IsMe ? "text-end" : "text-start")">
                                                <span class="small fw-bold @(msg.IsMe ? "text-primary" : "text-dark")">@(msg.IsMe ? "You" : msg.SenderName)</span>
                                                <br>
                                                <div class="p-2 rounded mt-1 shadow-sm @(msg.IsMe ? "bg-primary text-white" : "bg-white border text-dark")" style="display:inline-block; text-align:left; max-width:85%; word-break: break-word;">
                                                    @msg.MessageText
                                                </div>
                                                <div class="small text-muted mt-1" style="font-size: 0.7rem;">@msg.TimeAgo</div>
                                            </div>
                                        }
                                    }

                                }
                            </div>

                            <!-- Input Form -->
                            @if (task.Status != "Completed" && task.Status != "Pending" && task.Status != "Cancelled")
                            {
                                <div class="p-3 border-top bg-white">
                                    <form asp-controller="Task" asp-action="PostMessage" method="post">
                                        <input type="hidden" name="taskId" value="@task.TaskId" />
                                        <input type="hidden" name="returnTab" value="created-tab" />
                                        <div class="input-group dropup">
                                            <textarea class="form-control" name="messageText" rows="2" placeholder="Type a message..." required style="resize:none; font-size: 0.9rem;"></textarea>
                                            <button class="btn btn-primary" type="submit"><i class="bi bi-send-fill"></i></button>
                                        </div>
                                    </form>
                                </div>
                            }

                            <!-- Action Buttons -->
                            <div class="p-3 border-top bg-light">
                                @if (task.Status == "PendingReview")
                                {
                                    <div class="alert alert-warning border-0 shadow-sm p-3 text-center mb-0">
                                        <h6 class="fw-bold"><i class="bi bi-exclamation-triangle"></i> Review & Complete</h6>
                                        <p class="small mb-3">If the work delivered in the chat looks good, complete the task to release coins.</p>
                                        <form asp-controller="Task" asp-action="CompleteTask" method="post" id="completeTaskForm_@task.TaskId">
                                            <input type="hidden" name="id" value="@task.TaskId" />

                                            <!-- Changed: Default value is 0 -->
                                            <input type="hidden" name="score" id="ratingInput_@task.TaskId" value="0" />

                                            <div class="mb-3 border rounded p-2 bg-white text-center">
                                                <p class="small text-muted fw-bold mb-1">Rate the Worker to unlock Payment</p>

                                                <!-- Changed: All stars start as empty (bi-star) and grey (text-secondary) -->
                                                <div class="interactive-stars fs-5" data-taskid="@task.TaskId" style="cursor: pointer;">
                                                    <i class="bi bi-star text-secondary star-btn" data-val="1"></i>
                                                    <i class="bi bi-star text-secondary star-btn" data-val="2"></i>
                                                    <i class="bi bi-star text-secondary star-btn" data-val="3"></i>
                                                    <i class="bi bi-star text-secondary star-btn" data-val="4"></i>
                                                    <i class="bi bi-star text-secondary star-btn" data-val="5"></i>
                                                </div>
                                            </div>

                                            <!-- Changed: Added an ID and the 'disabled' tag so they CANNOT click it until rated -->
                                            <button type="submit" id="submitBtn_@task.TaskId" class="btn btn-success w-100 fw-bold" disabled onclick="return confirm('Transfer coins to @task.OtherUserName and rate them?');">
                                                <i class="bi bi-check-circle-fill"></i> Accept Work & Pay Coins
                                            </button>
                                        </form>


                                        <div class=""></div>
                                        <form asp-controller="Task" asp-action="RequestRevision" method="post" class="mt-2">
                                            <input type="hidden" name="id" value="@task.TaskId" />
                                            <button type="submit" class="btn btn-warning w-100 fw-bold" onclick="return confirm('Send the work back to the student for changes?');">
                                                <i class="bi bi-arrow-counterclockwise"></i> Request Changes
                                            </button>
                                        </form>

                                    </div>
                                }
                                else if (task.Status == "Accepted")
                                {
                                    <div class="alert alert-info border-0 text-center mb-0 p-2">
                                        <i class="bi bi-tools"></i> <strong>Work in Progress!</strong><br />
                                        <span class="small">Waiting for worker to submit work.</span>
                                    </div>
                                }
                                else if (task.Status == "Completed")
                                {
                                    <div class="alert alert-success border-0 text-center mb-0 p-2">
                                        <i class="bi bi-check-circle-fill"></i> <strong>Completed!</strong><br />
                                        <span class="small">Coins transferred successfully.</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- 2. Modals for ACCEPTED TASKS (User is Worker) -->
@foreach (var task in Model.AcceptedTasks)
{
    <div class="modal fade" id="taskModal_@task.TaskId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:12px; overflow:hidden;">
                
                <!-- Header -->
                <div class="modal-header bg-light d-flex justify-content-between align-items-start border-0">
                    <div>
                        <h5 class="fw-bold text-brand-grey mb-1">@task.Title</h5>
                        <span class="badge bg-success text-white">Earning: @task.CoinReward <i class="bi bi-coin"></i></span>
                        <span class="badge border border-secondary text-dark ms-1">Status: @task.Status</span>
                    </div>
                    <button type="button" class="btn-close mt-1" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-0">
                    <div class="row g-0">
                        <!-- LEFT COLUMN: Task Details -->
                        <div class="col-md-7 p-4 border-end">
                            <h6 class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Description</h6>
                            <div class="p-3 rounded bg-light mb-4">
                                <p class="mb-0 text-dark" style="white-space: pre-line;">@task.Description</p>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.8rem;">Creator Info</h6>
                                <div class="d-flex align-items-center gap-2 p-3 rounded" style="background:#f8f9fa; border:1px solid #dee2e6;">
                                    <i class="bi bi-person-fill fs-4 text-primary"></i>
                                    <span class="fw-semibold text-dark">@task.OtherUserName <span class="text-muted small">(@task.OtherUserRating <i class="bi bi-star-fill text-warning"></i>)</span></span>
                                </div>
                            </div>
                        </div>

                        <!-- RIGHT COLUMN: Chat & Actions -->
                        <div class="col-md-5 d-flex flex-column" style="background: #f9fafb;">

                            <!-- Chat Feed -->
                            <div class="p-3 flex-grow-1" style="min-height: 250px; max-height: 400px; overflow-y: auto;">
                                <h6 class="fw-bold text-muted mb-3"><i class="bi bi-chat-dots"></i> Task Handover Activity</h6>
                                @if (task.Messages == null || !task.Messages.Any())
                                {
                                    <p class="text-muted small text-center mt-4">No activity yet. Share your Google Drive link here.</p>
                                }
                                else
                                {
                                    @foreach (var msg in task.Messages)
                                    {
                                        @if (msg.MessageText.StartsWith("SYSTEM:"))
                                        {
                                            <!-- System Message -->
                                            <div class="text-center my-3">
                                                <span class="badge bg-secondary rounded-pill py-2 px-3 shadow-sm text-wrap" style="max-width: 90%; font-weight: normal;">
                                                    <i class="bi bi-info-circle me-1"></i> @msg.MessageText.Replace("SYSTEM:", "")
                                                </span>
                                                <div class="small text-muted mt-1" style="font-size: 0.65rem;">@msg.TimeAgo</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Normal Message -->
                                            <div class="mb-3 @(msg.IsMe ? "text-end" : "text-start")">
                                                <span class="small fw-bold @(msg.IsMe ? "text-primary" : "text-dark")">@(msg.IsMe ? "You" : msg.SenderName)</span>
                                                <br>
                                                <div class="p-2 rounded mt-1 shadow-sm @(msg.IsMe ? "bg-primary text-white" : "bg-white border text-dark")" style="display:inline-block; text-align:left; max-width:85%; word-break: break-word;">
                                                    @msg.MessageText
                                                </div>
                                                <div class="small text-muted mt-1" style="font-size: 0.7rem;">@msg.TimeAgo</div>
                                            </div>
                                        }
                                    }

                                }
                            </div>

                            <!-- Input Form -->
                            @if (task.Status != "Completed")
                            {
                                <div class="p-3 border-top bg-white">
                                    <form asp-controller="Task" asp-action="PostMessage" method="post">
                                        <input type="hidden" name="taskId" value="@task.TaskId" />
                                        <input type="hidden" name="returnTab" value="accepted-tab" />
                                        <div class="input-group dropup">
                                            <textarea class="form-control" name="messageText" rows="2" placeholder="Send Google Drive link or message..." required style="resize:none; font-size: 0.9rem;"></textarea>
                                            <button class="btn btn-primary" type="submit"><i class="bi bi-send-fill"></i></button>
                                        </div>
                                    </form>
                                </div>
                            }

                            <!-- Action Buttons -->
                            <div class="p-3 border-top bg-light">
                                @if (task.Status == "Accepted")
                                {
                                    <form asp-controller="Task" asp-action="DeliverWork" method="post">
                                        <input type="hidden" name="taskId" value="@task.TaskId" />
                                        <button type="submit" class="btn btn-warning w-100 fw-bold shadow-sm" onclick="return confirm('Have you dropped the link in the chat? Submit this task for review now?');">
                                            <i class="bi bi-box-arrow-up-right"></i> Submit Work For Review
                                        </button>
                                    </form>
                                <form asp-controller="Task" asp-action="DropTask" method="post" class="mt-2">
                                            <input type="hidden" name="id" value="@task.TaskId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm w-100 fw-bold shadow-sm" onclick="return confirm('Are you sure you want to drop this task?');">
                                                <i class="bi bi-trash"></i> Drop Task
                                            </button>
                                        </form>
                                }
                                else if (task.Status == "PendingReview")
                                {
                                    <div class="alert alert-warning border-0 text-center mb-0 p-2">
                                        <i class="bi bi-hourglass-split"></i> <strong>Under Review</strong><br />
                                        <span class="small">Waiting for the creator to accept your work.</span>
                                    </div>
                                }
                                else if (task.Status == "Completed")
                                {
                                    <div class="alert alert-success border-0 text-center mb-0 p-2">
                                        <i class="bi bi-check-circle-fill"></i> <strong>Great Job!</strong><br />
                                        <span class="small">Coins transferred to your account.</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
        // Interactive Star Logic
        document.addEventListener("DOMContentLoaded", function () {
        var activeTab = '@TempData["ActiveTab"]';
        if (activeTab) {
            var tabElement = document.getElementById(activeTab);
            if(tabElement) {
               var bsTab = new bootstrap.Tab(tabElement);
               bsTab.show();
            }
        }
    });
    /* =========================================
       2. CHAT AUTO-SCROLL (Restored)
       Scrolls chat to the bottom when modal opens
       ========================================= */
    var modals = document.querySelectorAll('.modal');
    modals.forEach(function(modal) {
        modal.addEventListener('shown.bs.modal', function () {
            var chatFeed = modal.querySelector('div[style*="overflow-y: auto"]');
            if(chatFeed) {
                chatFeed.scrollTop = chatFeed.scrollHeight;
            }
        });
    });

    document.querySelectorAll('.interactive-stars').forEach(container => {
         const stars = container.querySelectorAll('.star-btn');
         const taskId = container.getAttribute('data-taskid');
         const hiddenInput = document.getElementById('ratingInput_' + taskId);

         // Grab the specific disabled submit button for this task modal
         const submitBtn = document.getElementById('submitBtn_' + taskId);
         stars.forEach(star => {
             star.addEventListener('click', function() {
                 let ratingValue = parseInt(this.getAttribute('data-val'));
                 hiddenInput.value = ratingValue;
                 // UNLOCK the Submit Button now that they clicked a star!
                 if(submitBtn) {
                     submitBtn.disabled = false;
                 }
                 // Loop through all 5 stars to color them yellow or grey
                 stars.forEach(s => {
                     let thisStarVal = parseInt(s.getAttribute('data-val'));
                     if (thisStarVal <= ratingValue) {
                         s.classList.replace('bi-star', 'bi-star-fill');
                         s.classList.remove('text-secondary');
                         s.classList.add('text-warning'); // Yellow
                     } else {
                         s.classList.replace('bi-star-fill', 'bi-star');
                         s.classList.remove('text-warning');
                         s.classList.add('text-secondary'); // Grey
                     }
                 });
             });
         });
     });

</script>
