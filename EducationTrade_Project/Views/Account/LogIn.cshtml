@model EducationTrade.Core.DTOs.LoginDto

@{
    ViewData["Title"] = "Log in";
}

<!-- Custom layout styles for the full-page centered form -->
<style>
    body {
        background-color: #f8f9fa; /* Very light gray background for the full window */
    }

    .auth-wrapper {
        min-height: calc(100vh - 200px); /* Keeps it vertically centered between header/footer */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08); /* Premium, soft shadow */
        overflow: hidden;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card">

        
        <div class="border-bottom-0 pt-4 pb-0 px-4 px-md-5">
            <img src="~/images/logo.png" alt="EducationTrade Logo" style="height: 36px; margin-bottom: 24px;" />
        </div>

      
        <div class="px-4 px-md-5 pt-2 pb-5 text-start">
            <h3 class="fw-bold text-dark mb-1">Sign in</h3>
            <p class="text-secondary mb-4">to continue to EducationTrade</p>

            <form asp-action="Login" asp-controller="Account" method="post">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success small py-2 border-0 fw-medium">
                        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                    </div>
                }

                
                <div asp-validation-summary="ModelOnly" class="text-danger small fw-medium mb-3"></div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label fw-medium text-dark small">Email address</label>
                    <input asp-for="Email" class="form-control form-control-lg bg-light border-light-subtle fs-6" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label asp-for="Password" class="form-label fw-medium text-dark small mb-0">Password</label>
                        <a asp-controller="Account" asp-action="ForgotPassword" class="text-decoration-none">
                            Forgot Password?
                        </a>
                    </div>
                    <div class="input-group mt-2">
                        <input asp-for="Password" type="password" class="form-control form-control-lg bg-light border-light-subtle border-end-0 fs-6" placeholder="Enter your password" />
                        <span class="input-group-text bg-light border-light-subtle border-start-0 toggle-password-btn" style="cursor: pointer;">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-lg fw-medium mt-2 fs-6">Sign in</button>
            </form>

            <!-- Social Login Divider -->
            <div class="social-login-divider">
                <span>or continue with</span>
            </div>

            <!-- Google Login Button -->
            <a href="/Account/ExternalLogin?provider=Google" class="btn-social btn-google">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                </svg>
                Continue with Google
            </a>

            <!-- GitHub Login Button -->
            <a href="/Account/ExternalLogin?provider=GitHub" class="btn-social btn-github">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                </svg>
                Continue with GitHub
            </a>

        </div>

        
        <div class="bg-light border-top-0 py-3 text-center">
            <span class="text-secondary small">
                New to EducationTrade?
                <a asp-action="Register" asp-controller="Account" hx-boost = "true" class="text-primary fw-medium text-decoration-none">Create an account</a>
            </span>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
