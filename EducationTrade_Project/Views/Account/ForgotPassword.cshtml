@model EducationTrade.Core.DTOs.ForgotPasswordDto

@{
    ViewData["Title"] = "Forgot Password";
}

<h2>Forgot Password</h2>
<p class="mb-4">Enter your email address to receive a password reset link.</p>

<form asp-action="ForgotPassword" method="post" style="max-width: 400px;">
    <div class="form-group mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="text-danger mb-3">
        @Html.ValidationSummary(true)
    </div>

    <button type="submit" class="btn btn-primary w-100 mb-2">Send Reset Link</button>
    <div class="text-center">
        <a asp-action="Login" class="text-decoration-none">Back to Login</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
