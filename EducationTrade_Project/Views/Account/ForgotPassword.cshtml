@model EducationTrade.Core.DTOs.ForgotPasswordDto

@{
    ViewData["Title"] = "Password Recovery";
}


<div class="row justify-content-center align-items-center" style="min-height: 75vh;">

    <div class="col-12 col-md-8 col-lg-5">

        
        <div class="card border rounded-3 p-4 p-md-5" style="background-color: white; border-color: #e0e0e0 !important; box-shadow: none;">

            <h3 class="text-center  mb-4" style="color: #222; font-size: 24px;">Password recovery</h3>

            <p class="text-muted mb-4" style="font-size: 15px; line-height: 1.5;">
                Enter the email address associated with your education trade account.
            </p>

            <form asp-action="ForgotPassword" method="post">

                <div class="form-group mb-4">
                    <label asp-for="Email" class="form-label fw-bold" style="font-size: 13px; color: #222;">Email or username</label>
                    <input asp-for="Email" class="form-control" style="font-size: 15px; border-radius: 6px; padding: 10px 12px; border-color: #e0e0e0;" placeholder="noraizasad95@gmail.com" />
                    <span asp-validation-for="Email" class="text-danger mt-1 d-block" style="font-size: 12px;"></span>
                </div>

                <div class="text-danger mb-3" style="font-size: 13px;">
                    @Html.ValidationSummary(true)
                </div>

                
                <button type="submit" class="btn w-100 mb-4 fw-bold" style="color: #14a800; border: 2px solid #14a800; background-color: transparent; font-size: 15px; padding: 10px; border-radius: 8px; transition: all 0.2s;" onmouseover="this.style.backgroundColor='#14a800'; this.style.color='white';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#14a800';">
                    Continue
                </button>

                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none fw-bold" style="color: #14a800; font-size: 14px;">
                        Back
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
