@model EducationTrade.Core.DTOs.ResetPasswordDto

@{
    ViewData["Title"] = "Reset Password";
}

<h2>Reset Password</h2>
<p class="mb-4">Please enter your new password below.</p>

<form asp-action="ResetPassword" method="post" style="max-width: 400px;">
    <!-- Hidden fields for Email and Token so they are submitted to the server -->
    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Token" />

    <div class="form-group mb-3">
        <label asp-for="NewPassword" class="form-label">New Password</label>
        <input asp-for="NewPassword" type="password" class="form-control" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>

    <div class="form-group mb-4">
        <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password</label>
        <input asp-for="ConfirmNewPassword" type="password" class="form-control" />
        <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
    </div>

    <div class="text-danger mb-3">
        @Html.ValidationSummary(true)
    </div>

    <button type="submit" class="btn btn-success w-100 mb-2">Reset My Password</button>
    <div class="text-center">
        <a asp-action="Login" class="text-decoration-none">Back to Login</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
