@model EducationTrade.Core.DTOs.ResetPasswordDto

@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">

    <div class="col-12 col-md-8 col-lg-5">

        <div class="card border rounded-3 p-4 p-md-5" style="background-color: white; border-color: #e0e0e0 !important; box-shadow: none;">

            <!-- Logo -->
            <div class="text-center mb-4">
                <img src="~/images/logo.png" alt="EducationTrade Logo" style="height: 40px;" />
            </div>

            <h3 class="text-center mb-2" style="color: #222; font-size: 24px;">Reset your password</h3>
            <p class="text-muted text-center mb-4" style="font-size: 15px; line-height: 1.5;">
                Please enter and confirm your new password below.
            </p>

            <!-- Hidden fields — must be submitted with the form -->
            <form asp-action="ResetPassword" method="post">
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <div class="text-danger mb-3" style="font-size: 13px;">
                    @Html.ValidationSummary(true)
                </div>

                <!-- New Password -->
                <div class="form-group mb-4">
                    <label asp-for="NewPassword" class="form-label fw-bold" style="font-size: 13px; color: #222;">New Password</label>
                    <div class="input-group">
                        <input asp-for="NewPassword" type="password"
                               class="form-control border-end-0"
                               style="font-size: 15px; border-radius: 6px 0 0 6px; padding: 10px 12px; border-color: #e0e0e0;"
                               placeholder="Enter new password" />
                        <span class="input-group-text border-start-0 toggle-password-btn"
                              style="cursor: pointer;  background-color: #fff; border-radius: 0 6px 6px 0;">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger mt-1 d-block" style="font-size: 12px;"></span>
                </div>

                <!-- Confirm Password -->
                <div class="form-group mb-4">
                    <label asp-for="ConfirmNewPassword" class="form-label fw-bold" style="font-size: 13px; color: #222;">Confirm New Password</label>
                    <div class="input-group">
                        <input asp-for="ConfirmNewPassword" type="password"
                               class="form-control border-end-0"
                               style="font-size: 15px; border-radius: 6px 0 0 6px; padding: 10px 12px; border-color: #e0e0e0;"
                               placeholder="Confirm new password" />
                        <span class="input-group-text border-start-0 toggle-password-btn"
                              style="cursor: pointer;  background-color: #fff; border-radius: 0 6px 6px 0;">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger mt-1 d-block" style="font-size: 12px;"></span>
                </div>

                <!-- Green button matching ForgotPassword style -->
                <button type="submit" class="btn w-100 mb-4 fw-bold"
                        style="color: #14a800; border: 2px solid #14a800; background-color: transparent; font-size: 15px; padding: 10px; border-radius: 8px; transition: all 0.2s;"
                        onmouseover="this.style.backgroundColor='#14a800'; this.style.color='white';"
                        onmouseout="this.style.backgroundColor='transparent'; this.style.color='#14a800';">
                    Reset My Password
                </button>

                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none fw-bold" style="color: #14a800; font-size: 14px;">
                        Back to Login
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
        