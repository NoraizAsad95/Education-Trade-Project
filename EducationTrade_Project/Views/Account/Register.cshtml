@model EducationTrade.Core.DTOs.RegisterDto

@{
    ViewData["Title"] = "Create an account";
}

<!-- Custom layout styles for the full-page centered form -->
<style>
    body {
        background-color: #f8f9fa;
    }

    .auth-wrapper {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .auth-card {
        width: 100%;
        max-width: 500px; /* Slightly wider than login for the 2-column row */
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card">

      
        <div class="border-bottom-0 pt-4 pb-0 px-4 px-md-5">
            <img src="~/images/logo.png" alt="EducationTrade Logo" style="height: 36px; margin-bottom: 24px;" />
        </div>

       
        <div class="px-4 px-md-5 pt-2 pb-5 text-start">
            <h3 class="fw-bold text-dark mb-1">Create an account</h3>
            <p class="text-secondary mb-4">Start your journey with EducationTrade</p>

            
            <form asp-action="Register" asp-controller="Account" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger small fw-medium mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-medium text-dark small">Full name</label>
                    <input asp-for="FullName" class="form-control form-control-lg bg-light border-light-subtle fs-6" placeholder="Jane Doe" />
                    <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-medium text-dark small">Email address</label>
                    <input asp-for="Email" class="form-control form-control-lg bg-light border-light-subtle fs-6" placeholder="name@company.com" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-medium text-dark small">Password</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control form-control-lg bg-light border-light-subtle border-end-0 fs-6" placeholder="Create a strong password" />
                        <span class="input-group-text bg-light border-light-subtle border-start-0 toggle-password-btn" style="cursor: pointer;">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>


                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Course" class="form-label fw-medium text-dark small">Course</label>
                        <input asp-for="Course" class="form-control form-control-lg bg-light border-light-subtle fs-6" placeholder="e.g. Computer Science" />
                        <span asp-validation-for="Course" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label asp-for="Specialty" class="form-label fw-medium text-dark small">Specialty</label>
                        <input asp-for="Specialty" class="form-control form-control-lg bg-light border-light-subtle fs-6" placeholder="e.g. Programming" />
                        <span asp-validation-for="Specialty" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-lg fw-medium mt-2 fs-6">Create account</button>
            </form>
        </div>

        
        <div class="bg-light border-top-0 py-3 text-center">
            <span class="text-secondary small">
                Already have an account?
                
                <a asp-action="Login" asp-controller="Account" hx-boost="true" class="text-primary fw-medium text-decoration-none">Sign in</a>
            </span>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
